{
  "name": "@vue-native/sandbox",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./index.js",
  "scripts": {
    "start": "expo start",
    "prebuild:android": "expo prebuild --platform android",
    "native:sync:android": "node ./scripts/sync-native-android.mjs",
    "native:check:android": "node ./scripts/check-android-readiness.mjs",
    "native:run:android": "pnpm prebuild:android && pnpm native:sync:android && pnpm native:check:android && expo run:android",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "^5.0.4",
    "@vue-native/runtime-native": "workspace:*",
    "expo": "^52.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-native": "^0.76.0",
    "react-native-safe-area-context": "^4.12.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.6",
    "typescript": "^5.6.3"
  }
}