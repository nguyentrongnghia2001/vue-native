{
  "name": "vue-native",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.31.0",
  "type": "module",
  "scripts": {
    "dev:sandbox": "pnpm --filter @vue-native/sandbox start",
    "test": "vitest run",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "build": "pnpm -r build"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "devDependencies": {
    "@types/node": "^24.10.1",
    "vitest": "^4.0.18",
    "typescript": "^5.6.3",
    "tsx": "^4.19.2"
  }
}